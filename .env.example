# --- Anthropic (Claude) ---
# Utilise pour : generation des articles, scoring, categorisation, script dialogue
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Google Gemini ---
# Utilise pour : synthese vocale TTS (generation audio podcast)
GEMINI_API_KEY=your-gemini-api-key

# --- Google Cloud (Vertex AI) ---
# Utilise pour : generation d'images (Imagen 3 via Vertex AI)
# Fichier JSON de credentials du service account Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=./src/config/google-cloud-credentials.json
GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id

# --- Supabase ---
# Utilise pour : stockage des articles, upload audio/images
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
